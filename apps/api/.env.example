# API Environment Variables
# Copy to .env and fill in values

NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000
APP_URL=http://localhost:3001

# Database (Neon PostgreSQL)
# Get your connection string from: https://console.neon.tech
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/dbname?sslmode=require
DIRECT_URL=postgresql://user:password@ep-xxx.neon.tech/dbname?sslmode=require
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# Redis (optional - set ENABLE_REDIS=true to use)
ENABLE_REDIS=false
# REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=local-development-secret-key-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# AWS (optional for local)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=local-dev-key
AWS_SECRET_ACCESS_KEY=local-dev-secret
S3_BUCKET_NAME=salon-ops-local

# Logging
LOG_LEVEL=debug

# Feature Flags
ENABLE_REDIS=false

# Module Feature Flags (Phase 1 pilot: only core modules enabled)
ENABLE_INVENTORY=false
ENABLE_MEMBERSHIPS=false
ENABLE_ONLINE_BOOKING=false
ENABLE_MARKETING=false
