# API Environment Variables
# Copy to .env and fill in values

NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000
APP_URL=http://localhost:3001

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/trimio
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/trimio
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# Redis
# REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=local-development-secret-key-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Internal Admin Portal
INTERNAL_ADMIN_TOKEN_EXPIRY=8h

# AWS (optional for local)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=local-dev-key
AWS_SECRET_ACCESS_KEY=local-dev-secret
S3_BUCKET_NAME=trimio-local

# Email (AWS SES)
EMAIL_FROM=noreply@trimio.com
EMAIL_FROM_NAME=Trimio

# Logging
LOG_LEVEL=debug

# Development Testing
# API_DELAY_MS=500  # Uncomment to add artificial delay (ms) to simulate network latency

# Feature Flags
ENABLE_REDIS=false

# Module Feature Flags (Phase 1 pilot: only core modules enabled)
ENABLE_INVENTORY=false
ENABLE_MEMBERSHIPS=false
ENABLE_ONLINE_BOOKING=false
ENABLE_MARKETING=false

# Trimio Details
TRIMIO_SUPPORT_EMAIL=support.trimio@gmail.com
TRIMIO_APP_LOGIN_URL=https://app.trimio.in/login